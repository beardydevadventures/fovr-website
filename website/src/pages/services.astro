---
import Layout from '@/layouts/PageLayout.astro';

const metadata = {
  title: 'Services moved',
  description:
    'FoVR Interactive has retired its old services page. View projects or contact FoVR about XR prototypes, learning experiences and support.',
};
---

<Layout metadata={metadata}>
  <section class="relative px-4 py-24 sm:px-6 lg:py-32">
    <div class="mx-auto max-w-4xl rounded-[2rem] border border-slate-200/70 bg-white p-8 text-center shadow-2xl shadow-slate-200/70 dark:border-white/10 dark:bg-slate-900 dark:shadow-black/20 sm:p-12">
      <p class="text-sm font-black uppercase tracking-[0.18em] text-cyan-600 dark:text-cyan-300">FoVR Interactive</p>
      <h1 class="mt-4 text-4xl font-black tracking-tight text-slate-950 dark:text-white sm:text-5xl">
        The old Services page has been retired.
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300">
        FoVR is now organised around released projects and lab experiments. For the clearest view of the work, start with the project collection. For a new XR idea, support question or prototype conversation, head to Contact.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a class="rounded-full bg-cyan-400 px-5 py-3 font-black text-slate-950 shadow-lg shadow-cyan-400/20 transition hover:-translate-y-0.5" href="/projects">View projects</a>
        <a class="rounded-full border border-slate-300 px-5 py-3 font-black text-slate-950 transition hover:-translate-y-0.5 dark:border-white/15 dark:text-white" href="/contact">Contact FoVR</a>
      </div>
    </div>
  </section>
</Layout>
