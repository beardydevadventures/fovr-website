---
import Layout from '@/layouts/PageLayout.astro';

import Header from '@/components/widgets/Header.astro';

import Hero2 from '@/components/widgets/Hero2.astro';
import CallToAction from '@/components/widgets/CallToAction.astro';
import Steps from '@/components/widgets/Steps.astro';
import Features3 from '@/components/widgets/Features3.astro';
import Content from '@/components/widgets/Content.astro';
import Testimonials from '@/components/widgets/Testimonials.astro';
import FAQs from '@/components/widgets/FAQs.astro';
import Stats from '@/components/widgets/Stats.astro';

import Button from '@/components/ui/Button.astro';
import Image from '@/components/common/Image.astro';
import { YouTube } from 'astro-embed';

const appLabDownloadLink = 'https://www.oculus.com/deeplink/?action=view&path=/app/8298310513542583';

const metadata = {
  title: 'Valve Tutorial',
};
---

<Layout metadata={metadata}>
  <Hero2
    tagline="Immersive Learning Experience"
    image={{
      src: '@/assets/images/valve-tutorial.jpg',
      alt: 'Valve Tutorial hero image',
    }}
  >
    <Fragment slot="title">
      <span class="text-accent dark:text-white highlight">Valve Tutorial</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        A mixed reality valve training experience for Quest. Learn operation and assembly through guided, hands-on modules using hand tracking, with the option to switch into full VR for focus.
      </span>
    </Fragment>
  </Hero2>

  <!-- Youtube Video ************** -->

  <div class="container mx-auto px-4 sm:px-6">
    <YouTube id="wP6mO2jT8-E" title="Valve Tutorial" />
    <style is:inline>
      lite-youtube {
        display: block;
        margin: 0 auto;
        max-width: 960px;
        width: 100%;
      }
    </style>
  </div>
  <!-- Features3 Widget ************** -->

  <Features3
    title="Goals and Objectives"
    columns={3}
    items={[
      {
        title: 'Enhance Learning',
        description:
          'Provide an engaging and interactive training environment to improve understanding and retention of valve operation through guided modules and interaction.',
        icon: 'tabler:square-number-1',
      },
      {
        title: 'Risk-Free Learning',
        description:
          'Provide a safe virtual environment where users can explore, make mistakes, and learn without risk to themselves or damage to real equipment.',
        icon: 'tabler:square-number-2',
      },
      {
        title: 'Hands-On Experience',
        description:
          'Offer a practical experience with hand tracking and mixed reality that mirrors real-world handling of components.',
        icon: 'tabler:square-number-3',
      },
    ]}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    isReversed
    title="Process and Development"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Concept and learning flow</span>',
        description:
          'Collaborated with industry experts to define the learning objectives, valve operation flow, and assembly sequence.',
        icon: 'tabler:bulb',
      },
      {
        title: 'Step 2: <span class="font-medium">Model and interaction design</span>',
        description:
          'Developed detailed designs and prototypes to visualise interactive elements and user flow within the experience.',
        icon: 'tabler:pencil',
      },
      {
        title: 'Step 3: <span class="font-medium">Build in Unity for Quest</span>',
        description:
          'Utilised Unity to build the experience for Quest, incorporating realistic valve models, animations, and interactive features.',
        icon: 'tabler:code',
      },
      {
        title: 'Step 4: <span class="font-medium">Playtesting and iteration</span>',
        description:
          'Conducted extensive testing to ensure functionality, usability, and accuracy. Iterated based on feedback to refine the experience.',
        icon: 'tabler:arrow-iteration',
      },
      {
        title: 'Step 5: <span class="font-medium">Ongoing updates</span>',
        description:
          "Continue improving modules, interactions, and clarity based on user feedback and new requirements.",
        icon: 'tabler:cube-send',
      },
    ]}
    image={{
      src: '@/assets/images/valve-tute-vert.jpg',
      alt: 'Steps image',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Challenges and Solutions"
    items={[
      {
        title: 'Challenge: Ensuring Realism and Accuracy',
        description:
          'Solution: Collaborated with industry experts to validate the accuracy of valve models and operational procedures. Utilised high-quality 3D modeling and realistic animations to enhance immersion.',
      },
      {
        title: 'Challenge: Optimising Performance',
        description:
          'Solution: Focused on optimising assets and code to maintain high performance, ensuring a smooth and responsive VR experience without compromising on visual quality.',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    items={[
      {
        title: 'Clearer Understanding',
        description: 'Guided, hands-on modules help users understand valve operation and component relationships.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Safe Learning Environment',
        description: 'Learn and experiment in a virtual environment where mistakes carry no risk to people or equipment, so users can explore and learn without pressure.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Positive Feedback',
        description:
          'Users consistently call out the clarity of the guided flow and the value of interacting with parts directly.',
        icon: 'tabler:thumb-up',
      },
    ]}
    image={{
      src: '@/assets/images/valve-tute-rni.jpg',
      alt: 'Overlooking a bench with valve parts.',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Results and Impact</h3>
    </Fragment>
  </Content>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    id="download"
    title="Download Valve Tutorial now!"
    subtitle="Explore the valve in your own space with mixed reality, then switch into full VR when you want focus. Available on Meta Quest."
    actions={[
      {
        variant: 'primary',
        text: 'Meta Store',
        href: appLabDownloadLink,
        icon: 'tabler:brand-meta',
      },
    ]}
  />
</Layout>
